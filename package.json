{
  "name": "ouroboros-worker",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:css": "tailwindcss -i src/ui/styles/tailwind.source.css -o src/ui/styles/tailwind.generated.css --minify",
    "worker:dev": "npm run build:css && wrangler dev",
    "worker:deploy": "npm run build:css && wrangler deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "diff": "^9.0.0",
    "hono": "^4.12.30"
  },
  "devDependencies": {
        "@cloudflare/workers-types": "^5.20260710.1",
        "@tailwindcss/cli": "^4.3.3",
        "@types/diff": "^8.0.0",
        "@types/node": "^26.1.1",
        "typescript": "^7.0.2",
        "daisyui": "^5.6.13",
        "tailwindcss": "^4.3.2",
        "vitest": "^4.1.10",
        "wrangler": "^4.112.0"
  }
}
