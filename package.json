{
  "name": "ouroboros-worker",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:css": "tailwindcss -i src/ui/styles/tailwind.source.css -o src/ui/styles/tailwind.generated.css --minify",
    "worker:dev": "npm run build:css && wrangler dev",
    "worker:deploy": "npm run build:css && wrangler deploy"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "diff": "^9.0.0",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@tailwindcss/cli": "^4.3.2",
    "@types/diff": "^5.0.0",
    "@types/node": "^22.0.0",
    "daisyui": "^5.6.13",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.103.0"
  }
}
