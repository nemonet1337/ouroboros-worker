# ── ローカルデプロイ（Docker Compose / ベアメタル）設定 ─────────────────
# このファイルはローカルデプロイ専用。サーバー起動時に自動で読み込まれる
# （既に環境にある変数が優先）。Cloudflare デプロイはこのファイルを使わず、
# AI は Workers AI バインディングのみ（wrangler.toml 参照）。

# Anthropic Claude API キー（AI 解析/修正/インスペクションエンジンが使用）
ANTHROPIC_API_KEY=sk-ant-...
OURO_AI_MODEL=claude-sonnet-4-20250514

# GitHub（PR/Issue 作成 — VCS プロバイダ。GitHub Actions ではありません）
GITHUB_TOKEN=ghp_...
GITHUB_REPOSITORY=your-org/your-repo
GITHUB_REPOSITORY_OWNER=your-org

# 自己修復対象のリポジトリ（コンテナにマウント）。既定はワーキングツリー。
OURO_REPO_ROOT=/repo
OURO_BASE_BRANCH=main

# ローカル状態
OURO_DB_PATH=/data/ouroboros.db
OURO_LOG_DIR=/logs
OURO_GUI_DIR=/app/web/.output/public

# Web サーバー
PORT=3000
OURO_COOKIE_SECURE=false

# 自己修復のスケジュール間隔（時間単位。0 で無効。Actions の cron を置き換え）
OURO_HEAL_INTERVAL_HOURS=24

# メールアラート（SMTP）。SMTP_HOST を空にするとメール送信は無効。
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ouroboros@localhost
SMTP_SECURE=false
OURO_ALERT_EMAILS=alerts@example.com

# エスカレーション Issue のアサイン先（カンマ区切りの GitHub ユーザー名）
SELF_HEALING_ASSIGNEES=

# エッジ Worker がこのサーバーへ重い自己修復処理を委譲するための共有シークレット
RUNNER_SHARED_SECRET=change-me

# スキャナーのレポートパス（任意）
CODEQL_SARIF_PATH=/results
LIGHTHOUSE_REPORT_PATH=/results/lighthouse.json
BENCH_REPORT_PATH=/results/benchmark.json
PERF_THRESHOLD_PCT=20
